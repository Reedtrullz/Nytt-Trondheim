NODE_ENV=development
PORT=8080
PUBLIC_ORIGIN=http://127.0.0.1:5173
DATABASE_URL=postgres://nytt:nytt@localhost:5432/nytt
DEV_AUTH_BYPASS=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

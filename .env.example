NODE_ENV=development
PORT=8080
PUBLIC_ORIGIN=http://127.0.0.1:5173
POSTGRES_PASSWORD=replace-in-local-development
DATABASE_URL=postgres://nytt:replace-in-local-development@localhost:5432/nytt
DEV_AUTH_BYPASS=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_LOGIN=Reedtrullz
SESSION_SECRET=replace-in-production
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
POLITILOGGEN_ENABLED=true
# Optional DATEX Situation endpoint override; blank uses the SRTI-filtered Vegvesen GetSituation default.
# Production secret name: NYTT_DATEX_ENDPOINT.
DATEX_ENDPOINT=
# DATEX II v3.1 Basic Auth credentials; never commit real values.
# Production secret names: NYTT_DATEX_USERNAME and NYTT_DATEX_PASSWORD.
DATEX_USERNAME=
DATEX_PASSWORD=
# Optional DATEX TravelTime endpoint overrides; blank uses Vegvesen defaults.
DATEX_TRAVEL_TIME_LOCATIONS_ENDPOINT=
DATEX_TRAVEL_TIME_DATA_ENDPOINT=
UPLOAD_DIR=./data/uploads

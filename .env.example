NODE_ENV=development
PORT=8080
PUBLIC_ORIGIN=http://127.0.0.1:5173
POSTGRES_PASSWORD=replace-in-local-development
DATABASE_URL=postgres://nytt:replace-in-local-development@localhost:5432/nytt
DEV_AUTH_BYPASS=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_LOGIN=Reedtrullz
SESSION_SECRET=replace-in-production
# SMTP is optional in development (links are logged) and required in production.
# Production secret names: NYTT_SMTP_HOST, NYTT_SMTP_FROM, NYTT_SMTP_API_KEY,
# NYTT_SMTP_PORT, NYTT_SMTP_SECURE, NYTT_SMTP_USER.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
# Optional derived AI analysis. Leave disabled unless explicitly testing AI-assisted hints.
DEEPSEEK_ANALYSIS_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=25000
DEEPSEEK_MAX_RETRIES=0
# `v2` enables shadow computation only; v1 remains persisted and public until Phase 3.
COVERAGE_MATCHER_VERSION=v1
# Optional Web Push keys. Generate VAPID keys before enabling browser notifications.
# Production secret names: NYTT_WEB_PUSH_VAPID_PUBLIC_KEY,
# NYTT_WEB_PUSH_VAPID_PRIVATE_KEY, NYTT_WEB_PUSH_SUBJECT.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@nytt-trondheim.local
POLITILOGGEN_ENABLED=true
# Optional timeout for public source/news fetches in milliseconds; blank uses 15000.
NYTT_FETCH_TIMEOUT_MS=
# Entur open-data APIs require identifying every request; this is not a secret.
ENTUR_CLIENT_NAME=reidar-nytt-trondheim
ENTUR_CODESPACES=ATB
ENTUR_VEHICLE_BOUNDS=63.30,10.20,63.55,10.65
# Optional DATEX Situation endpoint override; blank uses the SRTI-filtered Vegvesen GetSituation default.
# Production secret name: NYTT_DATEX_ENDPOINT.
DATEX_ENDPOINT=
# DATEX II v3.1 Basic Auth credentials; never commit real values.
# Production secret names: NYTT_DATEX_USERNAME and NYTT_DATEX_PASSWORD.
DATEX_USERNAME=
DATEX_PASSWORD=
# Optional DATEX TravelTime endpoint overrides; blank uses Vegvesen defaults.
DATEX_TRAVEL_TIME_LOCATIONS_ENDPOINT=
DATEX_TRAVEL_TIME_DATA_ENDPOINT=
UPLOAD_DIR=./data/uploads
